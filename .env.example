# Copy to .env for local dev. NEVER commit the real .env
# Supabase — the anon key is safe in the browser by design.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# NEVER put SUPABASE_SERVICE_ROLE_KEY here or anywhere in the frontend.
# It bypasses row-level security. It belongs only in Netlify env vars,
# used exclusively by serverless functions.
